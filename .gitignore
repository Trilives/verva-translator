# Build output
bin/
obj/
artifacts/
.build/
dist/
node_modules/
.npm-cache/
.cargo-home/
*.tsbuildinfo
src-tauri/target/
# Cargo invoked from the repository root rather than src-tauri lands here.
target/
src-tauri/tauri.release.conf.json
# Staging directory the release workflow builds; only meaningful inside a run.
release/
*.pdb
*.msi
*.msix
*.appx
*.appxbundle
*.exe

# Editor, IDE and agent tooling. These hold machine-specific absolute paths,
# so they must never be committed: .claude/launch.json carried a full local
# toolchain path, including the user name, before it was untracked.
.vs/
.vscode/
.idea/
.claude/
*.user
*.suo
*.userosscache
*.sln.docstates

# Test and coverage output
TestResults/
coverage/
*.coverage
*.coveragexml

# Local credentials and environment files
.env
.env.*
!.env.example
secrets.json

# Operating-system files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
